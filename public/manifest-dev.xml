<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>00000000-0000-0000-0000-000000000001</Id>
  <Version>1.1.0.0</Version>
  <ProviderName>Sophos</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="DealTrace" />
  <Description DefaultValue="Analyzes email threads and surfaces deal intelligence for sales reps." />

  <IconUrl DefaultValue="https://deal-trace-gse.vercel.app//icon-32.png" />
  <HighResolutionIconUrl DefaultValue="https://deal-trace-gse.vercel.app//icon-64.png" />
  <SupportUrl DefaultValue="https://deal-trace-gse.vercel.app/" />

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5" />
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://deal-trace-gse.vercel.app//taskpane" />
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>

          <FunctionFile resid="Commands.Url" />

          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="msgReadGroup">
                <Label resid="GroupLabel" />

                <Control xsi:type="Button" id="msgReadOpenPaneButton">
                  <Label resid="TaskpaneButton.Label" />
                  <Supertip>
                    <Title resid="TaskpaneButton.Label" />
                    <Description resid="TaskpaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image resid="Icon.16x16" size="16" />
                    <bt:Image resid="Icon.32x32" size="32" />
                    <bt:Image resid="Icon.80x80" size="80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="Taskpane.Url" />
                    <SupportsPinning>true</SupportsPinning>
                  </Action>
                </Control>

              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://deal-trace-gse.vercel.app//icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://deal-trace-gse.vercel.app//icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://deal-trace-gse.vercel.app//icon-64.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://deal-trace-gse.vercel.app//taskpane" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://deal-trace-gse.vercel.app//taskpane" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="DealTrace" />
        <bt:String id="TaskpaneButton.Label" DefaultValue="Open DealTrace" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Analyze this email thread and surface deal intelligence." />
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>

</OfficeApp>
